<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="(new model)" id="id-3687a676e0064c678953e4cfd77e1f55" version="5.0.0">
  <folder name="Strategy" id="id-737d4e887162492bb00521bc9043b41f" type="strategy"/>
  <folder name="Business" id="id-a376e4af2abd4672b91703546115a1fd" type="business"/>
  <folder name="Application" id="id-14e35c96d2f64c6d9f0b6dc97f95e9bb" type="application"/>
  <folder name="Technology &amp; Physical" id="id-0f1e883bd45e4ff1b21959170335c139" type="technology"/>
  <folder name="Motivation" id="id-1dd82fa1686a43eea04d91d366d1f5a1" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Dono da software house" id="id-65b404f56fb541ec9f0abd631b0dc27b"/>
    <element xsi:type="archimate:Driver" name="Formalização e controle administrativo sobre atividades de suporte técnico" id="id-7be3063642de48299118e07a1ba67284"/>
    <element xsi:type="archimate:Principle" name="Fazer registro formal de chamados técnicos" id="id-b4726badd47d41ffa8a419fe68c1c6d1"/>
    <element xsi:type="archimate:Principle" name="Controlar tempo de atendimento de cada chamado" id="id-c20f15623a1940ae920ddd5404ffcdfa"/>
    <element xsi:type="archimate:Principle" name="Medir a satisfação dos clientes" id="id-5538f4a2d15746acb199cf8cf791e4f5"/>
    <element xsi:type="archimate:Goal" name="Workflow do fluxo de atendimento de chamados " id="id-eac093237ab54bca90012d1aa997e797"/>
    <element xsi:type="archimate:Goal" name="Comunicação com o cliente demandante para feedbacks" id="id-d4f8a8a9c0e34d5bab590916f2a4a4cf"/>
    <element xsi:type="archimate:Goal" name="Gerar consultas, relatórios, dashboards de acompanhamento de desempenho do suporte" id="id-07940db2f5694cce926259fe9109ee4d"/>
    <element xsi:type="archimate:Assessment" name="Workflow digitalizado com apoio da IA em cada etapa do processo" id="id-3e7ca02d0450459b91ef0fefc0a8992f"/>
    <element xsi:type="archimate:Assessment" name="Usar um sistema de comunicação instantânea digital e público" id="id-e1e6b1257d8342dd914276894f555cc1"/>
    <element xsi:type="archimate:Assessment" name="Usar solução de BI de mercado" id="id-8e66caa2c2d546c9a291f3454868860a"/>
    <element xsi:type="archimate:Outcome" name="Aumentar o nível de satisfação dos clientes de forma gradual, a partir da implatação da solução" id="id-9be9d44c2af040f587f70ec5062a7394"/>
    <element xsi:type="archimate:Outcome" name="Garantir que 100% dos chamados resolvidos tenham uma pesquisa de satisfação" id="id-fe1265f954d043969de93205d940c792"/>
    <element xsi:type="archimate:Outcome" name="100% dos atendimentos de suporte registrados no sistema de informação disponibilizado" id="id-d8a5b023be9b41fca2bb8b097692c408"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-7f93af48d9bd48ef809039f7393e7914"/>
    <element xsi:type="archimate:Requirement" name="Registrar novo chamado" id="id-b31eb8910ca74d7797cd6fa461099319"/>
    <element xsi:type="archimate:Requirement" name="Triagem de chamados para encaminhamento" id="id-588e10d18aae4341a6461edd1cfcb514"/>
    <element xsi:type="archimate:Requirement" name="Registrar log de ação realizada no atendimento" id="id-ba769acea6aa4b6189e4e40468581bac"/>
    <element xsi:type="archimate:Requirement" name="Registrar solução para problema diagnosticado" id="id-770c832472f244fd8f7a2d3b4bfd3e0f"/>
    <element xsi:type="archimate:Constraint" name="Deve ser informado pelo usuário a identificação do cliente; a descrição do problema. O sistema deve gerar um número de protocícolo de registro do chamado, data e hora de abertura e a identificação do analista de suporte que fez o contato, atribuindo o status Pendente" id="id-1f0f3747d426495a9bf21c28dfb28fc2"/>
    <element xsi:type="archimate:Constraint" name="Um analista de suporte de 1° nível deve avaliar os chamados que estão pendenes e não têm equipe técnica associada para solução e, apontar uma equipe técnica, atualizando os dados do chamado" id="id-552cad76f52e4f3290e0fb59aa799c42"/>
    <element xsi:type="archimate:Constraint" id="id-9a2e7afb5a8d41ab8d9f6424d2459be2"/>
    <element xsi:type="archimate:Constraint" name="Um analista de uma equipe técnica vai acessar o 1° chamado pendente da fila atribuída à sua especialidade e, vai registrar a ação que tomou para tentar solucionar o caso e, o sistema vai registrar um log com os dados de identificação do analista, ação realizada, data e hora da operação" id="id-cfe64a577f464396a1914cc5cacd2462"/>
    <element xsi:type="archimate:Constraint" name="O analista de suporte que solucionou o problema de um chamado deve escrever o diagnóstico e a solução aplicada. O sistema irá atualizar  o status do chamado para fechado, guardando no chamado o diagnóstico e a solução. Além disso, o sistema vai alimentar uma base de dados de soluções conhecidas com a descrição do problema, o diagnóstico e a solução. A data e a hora das operações será guardada também em cada registro" id="id-d6d343f9179a425096531eea404dc064"/>
    <element xsi:type="archimate:Requirement" name="Disparar pesquisa de satisfação" id="id-19055a83d51f4c118453d3e99e3c1d71"/>
    <element xsi:type="archimate:Constraint" name="Constraint" id="id-27a66753ba2c49a6a234ec57160fb27b"/>
    <element xsi:type="archimate:Requirement" name="Coletar e guardar a reposta da pesquisa" id="id-c0c140cd50504336ad979bcc079b1582"/>
    <element xsi:type="archimate:Constraint" name="A mensagem deve conter um texto padrão explicando o objetivo da pesquisa, identificar o protocóloe a descrição do problema original, acompanhado de uma lista de perguntas com opções de repostas pré-configuradas (listas de opções)" id="id-7c7f4df6c5c34e7184d87905855f0a71"/>
    <element xsi:type="archimate:Constraint" name="Devem ser coletadas as respostas e guardados os seguintes dados: Identificação do cliente, identificação das pergunas e respostas escolhidas. Esses dados serão inseridos no banco de dados transacional do suporte para uso em consultas" id="id-e33df82e2e094ba28c2146034045d8d5"/>
    <element xsi:type="archimate:Requirement" name="Disponibilizar dados transacionais do suporte em um banco de dados Data Mart/DW" id="id-08422d84756e4dc6a20f27ad90f20c7e"/>
    <element xsi:type="archimate:Constraint" name="Construir uma aplicação ETL (Extração, Transformação e Carga) para ler as bases de dados transacionais do suporte e alimentar um banco de dados de consulta (DW/datamart)" id="id-e6ae2fb68e154169bce83cf15243a9fd"/>
  </folder>
