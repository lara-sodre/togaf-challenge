  <folder name="Application" id="id-14e35c96d2f64c6d9f0b6dc97f95e9bb" type="application"/>
  <folder name="Technology &amp; Physical" id="id-0f1e883bd45e4ff1b21959170335c139" type="technology"/>
  <folder name="Motivation" id="id-1dd82fa1686a43eea04d91d366d1f5a1" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Dono da software house" id="id-65b404f56fb541ec9f0abd631b0dc27b"/>
    <element xsi:type="archimate:Driver" name="Formalização e controle administrativo sobre atividades de suporte técnico" id="id-7be3063642de48299118e07a1ba67284"/>
    <element xsi:type="archimate:Principle" name="Fazer registro formal de chamados técnicos" id="id-b4726badd47d41ffa8a419fe68c1c6d1"/>
    <element xsi:type="archimate:Principle" name="Controlar tempo de atendimento de cada chamado" id="id-c20f15623a1940ae920ddd5404ffcdfa"/>
    <element xsi:type="archimate:Principle" name="Medir a satisfação dos clientes" id="id-5538f4a2d15746acb199cf8cf791e4f5"/>
    <element xsi:type="archimate:Goal" name="Workflow do fluxo de atendimento de chamados " id="id-eac093237ab54bca90012d1aa997e797"/>
    <element xsi:type="archimate:Goal" name="Comunicação com o cliente demandante para feedbacks" id="id-d4f8a8a9c0e34d5bab590916f2a4a4cf"/>
    <element xsi:type="archimate:Goal" name="Gerar consultas, relatórios, dashboards de acompanhamento de desempenho do suporte" id="id-07940db2f5694cce926259fe9109ee4d"/>
    <element xsi:type="archimate:Assessment" name="Workflow digitalizado com apoio da IA em cada etapa do processo" id="id-3e7ca02d0450459b91ef0fefc0a8992f"/>
    <element xsi:type="archimate:Assessment" name="Usar um sistema de comunicação instantânea digital e público" id="id-e1e6b1257d8342dd914276894f555cc1"/>
    <element xsi:type="archimate:Assessment" name="Usar solução de BI de mercado" id="id-8e66caa2c2d546c9a291f3454868860a"/>
    <element xsi:type="archimate:Outcome" name="Aumentar o nível de satisfação dos clientes de forma gradual, a partir da implantação da solução" id="id-7e1b71fb943249519d8bbaefa83cd815"/>
    <element xsi:type="archimate:Outcome" name="Garantir que 100% dos chamados resolvidos tenham uma pesquisa de satisfação disparada" id="id-531768bebdf246aebcc8dc5ed04518b9"/>
    <element xsi:type="archimate:Outcome" name="100% dos atendimentos de suporte registrados no sistema de informação disponibilizado" id="id-bf2f12929c00459f86135f991cffbfb5"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-4297a14e5d184884bdb7cee7191faaf0"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-4b9614ace568469e9753ef732019cdfe"/>
    <element xsi:type="archimate:Requirement" name="Registrar novo chamado" id="id-cd773c3bc84c4e20a208e31cd079fda0"/>
    <element xsi:type="archimate:Requirement" name="Triagem de chamados para encaminhamento" id="id-4df6f70b5d76413294de74d9485d8680"/>
    <element xsi:type="archimate:Requirement" name="Registrar log de ação realizada no atendimento" id="id-fbf83aabc6104c4ba9344fd7a8340d61"/>
    <element xsi:type="archimate:Requirement" name="Registrar solução para problema diagnosticado" id="id-b67ea681d90e4e0fb6fae2feb87aa6df"/>
    <element xsi:type="archimate:Constraint" name="Deve ser informado pelo usuário: a identificação do cliente; a descrição do problema. O sistema deve gerar um número de protocolo de registro do chamado, com a data e hora de abertura e a identificação do analista de suporte que fez o contato, atribuindo o status Pendente. Somente clientes com contrato de suporte terão registro de chamado" id="id-f147dc4ee42c4e269eb362536e650ec2"/>
    <element xsi:type="archimate:Constraint" name="Um analista do suporte de 1o nível deve avaliar os chamados que estão pendentes e não têm equipe técnica associada para solução e, apontar uma equipe técnica, atualizando os dados do chamado" id="id-6b2bb61c98b2460b936e35f178db463b"/>
    <element xsi:type="archimate:Constraint" name="Um analista de uma equipe técnica vai acessar o 1o chamado pendente da fila atribuída à sua especialidade e, vai registrar a ação que tomou para tentar solucionar o caso e, o sistema vai registrar um log com os dados de identificação do analista, ação realizada, data e hora da operação" id="id-28bd95711e9446caa70e71238d2f7dbd"/>
    <element xsi:type="archimate:Constraint" name="O analista de suporte que solucionou o problema de um chamado deve descrever o diagnóstico e a solução aplicada. O sistema irá atualizar o status do chamado para fechado, guardando no chamado o diagnóstico e a solução. Além disso, o sistema vai alimentar uma base de dados de soluções conhecidas com a descrição do problema, o diagnóstico e a solução. A data e hora das operções será guardada também em cada registro" id="id-ab98869642724d75bb6524a6a4d1b007"/>
    <element xsi:type="archimate:Requirement" name="Disparar pesquisa de satisfação" id="id-4b70d8522c904fc790f30efecbef5247"/>
    <element xsi:type="archimate:Requirement" name="Coletar e guardar a resposta da pesquisa" id="id-baa04e2d201f4640a61542964bdf9632"/>
    <element xsi:type="archimate:Constraint" name="A mensagem deve conter um texto padrão explicando o objetivo da pesquisa, identificar o protocolo e a descrição do problema original, acompanhado de uma lista de perguntas com opções de resposta pré-configuradas (lista de opções)" id="id-a99350c5f80f44e693907e0865a0a141"/>
    <element xsi:type="archimate:Constraint" name="Devem ser colteadas as respostas e guardados os seguintes dados: identificação do cliente, identificação do protocolo do chamado,identificação das perguntas e respostas escolhidas. Esses dados serão inserido no banco de dados transacional do suporte para uso em consultas" id="id-f504da24b4484100ad3e3cb7282acc25"/>
    <element xsi:type="archimate:Requirement" name="Disponibilizar dados transacionais do suporte em um banco de dado Data Mart/DW" id="id-aa82e87945354933bc51843d2845cd5c"/>
    <element xsi:type="archimate:Constraint" name="Construir uma aplicação ETL (Extração, Transformação e Carga) para ler as bases de dados transacionais do suporte e alimentar um banco de dados de consulta (DW/datamart)" id="id-e0377bfdd2d24de48dcbe1c7bbfc2fba"/>
  </folder>
